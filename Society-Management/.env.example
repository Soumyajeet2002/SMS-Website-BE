# Switch DB: postgres or mongo
DATABASE_TYPE=postgres

# Postgres
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/db_identity


# Redis toggle
REDIS_ENABLED=false
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=supersecretkey
JWT_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800
PORT=3002

# RabbitMQ (optional for notifications)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
